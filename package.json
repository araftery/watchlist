{
  "name": "watchlist",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "react-router build",
    "cf-typegen": "wrangler types",
    "deploy": "npm run build && wrangler deploy",
    "dev": "react-router dev",
    "postinstall": "npm run cf-typegen",
    "preview": "npm run build && vite preview",
    "typecheck": "npm run cf-typegen && react-router typegen && tsc -b",
    "db:generate": "drizzle-kit generate",
    "db:migrate:local": "wrangler d1 execute watchlist-db --local --file=./drizzle/0000_abandoned_loners.sql; wrangler d1 execute watchlist-db --local --file=./drizzle/0001_crazy_swarm.sql; wrangler d1 execute watchlist-db --local --file=./drizzle/0002_watched_seasons.sql"
  },
  "dependencies": {
    "@google/genai": "^1.42.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.1",
    "isbot": "^5.1.31",
    "lucide-react": "^0.575.0",
    "next-themes": "^0.4.6",
    "radix-ui": "^1.4.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router": "7.12.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tmdb-ts": "^2.3.0"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.13.7",
    "@react-router/dev": "7.12.0",
    "@tailwindcss/vite": "^4.1.13",
    "@types/node": "^22",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "drizzle-kit": "^0.31.9",
    "shadcn": "^3.8.5",
    "tailwindcss": "^4.1.13",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.9.2",
    "vite": "^7.1.7",
    "vite-tsconfig-paths": "^5.1.4",
    "wrangler": "^4.40.2"
  }
}
